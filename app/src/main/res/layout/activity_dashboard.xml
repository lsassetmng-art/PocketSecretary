<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootDashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <TextView
        android:id="@+id/textHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Persona Status -->
    <TextView
        android:id="@+id/textPersonaStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Persona Status"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textHeader"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Left Button Column -->
    <LinearLayout
        android:id="@+id/buttonColumn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/textPersonaStatus"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnOne"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:text="Action 1"
            android:background="@drawable/bg_btn_gray_3d"
            android:textColor="#222222"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnTwo"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:text="Action 2"
            android:background="@drawable/bg_btn_gray_3d"
            android:textColor="#222222"/>
    </LinearLayout>

    <!-- Avatar Host 右下固定 -->
    <FrameLayout
        android:id="@+id/avatarHost"
        android:layout_width="260dp"
        android:layout_height="420dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/avatarView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
